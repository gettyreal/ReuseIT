{
  "name": "reuseit/web-server",
  "description": "ReuseIT - Web Server Application",
  "type": "project",
  "require": {
    "php": ">=7.4",
    "vlucas/phpdotenv": "^5.5"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5"
  },
  "autoload": {
    "psr-4": {
      "ReuseIT\\": "src/"
    }
  },
  "scripts": {
    "start": "php -S localhost:8000",
    "install-deps": "composer install"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true
    }
  }
}
